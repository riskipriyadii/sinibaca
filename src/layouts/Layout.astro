---
import Sidebar from "../components/Sidebar.astro";
import RightPanel from "../components/RightPanel.astro";
import TopBar from "../components/TopBar.astro";

interface Props {
  title?: string;
  description?: string;
  noScroll?: boolean;
}

const { title = "sinibaca", description = "Blog modern dengan Astro", noScroll = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="id" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/x-icon" href="/sinibaca/favicons/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/sinibaca/favicons/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/sinibaca/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/sinibaca/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/sinibaca/favicons/site.webmanifest" />

    <link rel="icon" type="image/x-icon" href="/sinibaca/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <script is:inline>
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.setAttribute("data-mode", saved);
    </script>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-secondary: #f8fafc;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --border: #e2e8f0;
        --accent: #6366f1;
        --hover: #f1f5f9;
        --card-bg: #ffffff;
        transition: background 0.3s ease, color 0.3s ease;
      }
      html[data-mode="dark"] {
        --bg: #0a0a0a;
        --bg-secondary: #141414;
        --text: #f1f5f9;
        --text-muted: #94a3b8;
        --text-light: #64748b;
        --border: #1e1e1e;
        --accent: #818cf8;
        --hover: #1a1a1a;
        --card-bg: #141414;
      }
      html {
        scroll-behavior: smooth;
        font-family: "Inter", system-ui, sans-serif;
        overflow-x: hidden;
        -webkit-text-size-adjust: 100%;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        margin: 0;
        overflow-x: hidden;
        width: 100%;
        max-width: 100vw;
      }
      body.no-scroll {
        height: 100vh;
        overflow: hidden;
      }
      body.no-scroll .page-wrapper {
        min-height: 0;
        flex: 1;
        overflow: hidden;
        padding-top: 68px;
        padding-bottom: 16px;
      }
      body.no-scroll .main-content {
        overflow: hidden;
      }
      *, *::before, *::after {
        box-sizing: border-box;
      }
      img, video, canvas, svg {
        max-width: 100%;
        height: auto;
        display: block;
      }
      ::selection {
        background: rgba(99,102,241,0.2);
        color: var(--text);
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--text-muted);
      }
    </style>
  </head>
  <body class={noScroll ? "no-scroll" : ""}>
    <TopBar />
    <div class="page-wrapper">
      <aside class="sidebar-left">
        <Sidebar />
      </aside>
      <main class="main-content">
        <slot />
      </main>
      <aside class="sidebar-right">
        <RightPanel />
      </aside>
    </div>
    <footer class="site-footer">
      <p>&copy; 2026 sinibaca. Berbasis referensi.</p>
    </footer>
    <style>
      .page-wrapper {
        display: grid;
        grid-template-columns: 300px 1fr 400px;
        gap: 32px;
        padding: 80px 24px 40px;
        flex: 1;
        min-height: 0;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
      }

      .sidebar-left,
      .sidebar-right {
        width: 100%;
        min-width: 0;
      }

      .main-content {
        width: 100%;
        min-width: 0;
        overflow-x: hidden;
      }

      .site-footer {
        width: 100%;
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 16px 24px;
        color: var(--text-light);
        font-size: 0.875rem;
        min-height: 61px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow-x: hidden;
      }
      .site-footer p {
        margin: 0;
        word-break: break-word;
      }

      @media (max-width: 1200px) {
        .page-wrapper {
          grid-template-columns: 300px 1fr;
          gap: 32px;
        }
        .sidebar-right { display: none; }
        body.no-scroll .page-wrapper {
          grid-template-columns: 300px 1fr;
        }
      }

      @media (max-width: 900px) {
        .page-wrapper {
          grid-template-columns: 1fr;
          padding: 64px 16px 32px;
          gap: 0;
          width: 100%;
          max-width: 100vw;
          box-sizing: border-box;
          overflow-x: hidden;
        }
        body.no-scroll .page-wrapper {
          padding-top: 64px;
          padding-bottom: 14px;
        }
        .sidebar-left {
          display: none;
          position: fixed;
          top: 60px;
          left: 0;
          bottom: 0;
          width: 280px;
          max-width: 80vw;
          z-index: 90;
          background: var(--bg);
          border-right: 1px solid var(--border);
          padding: 20px;
          overflow-y: auto;
          box-sizing: border-box;
        }
        .sidebar-left.mobile-open {
          display: block;
        }
        .main-content {
          max-width: 100%;
          width: 100%;
          box-sizing: border-box;
          overflow-x: hidden;
        }
      }

      @media (max-width: 480px) {
        .page-wrapper {
          padding: 60px 12px 24px;
          width: 100%;
          max-width: 100vw;
          box-sizing: border-box;
          overflow-x: hidden;
        }
        body.no-scroll .page-wrapper {
          padding-top: 60px;
          padding-bottom: 10px;
        }
        .sidebar-left {
          width: 260px;
          max-width: 85vw;
          padding: 16px;
        }
        .site-footer {
          padding: 10px 12px;
          font-size: 0.75rem;
          min-height: auto;
        }
        .site-footer p {
          font-size: 0.75rem;
        }
        body.no-scroll {
          height: auto;
          overflow: visible;
        }
        body.no-scroll .page-wrapper {
          min-height: 0;
          flex: 1;
          overflow: visible;
          padding-top: 60px;
          padding-bottom: 10px;
        }
        body.no-scroll .main-content {
          overflow: visible;
        }
      }

      @media (max-width: 360px) {
        .page-wrapper {
          padding: 56px 12px 20px;
        }
        body.no-scroll .page-wrapper {
          padding-top: 56px;
          padding-bottom: 8px;
        }
        .sidebar-left {
          width: 240px;
          padding: 12px;
        }
        .site-footer {
          padding: 8px 10px;
        }
      }
    </style>
  </body>
</html>
