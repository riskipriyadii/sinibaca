---
import Sidebar from "../components/Sidebar.astro";
import RightPanel from "../components/RightPanel.astro";
import TopBar from "../components/TopBar.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "sinibaca", description = "Blog modern dengan Astro" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-secondary: #f8fafc;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --border: #f1f5f9;
        --accent: #6366f1;
      }
      html[data-mode="dark"] {
        --bg: #0a0a0a;
        --bg-secondary: #141414;
        --text: #f1f5f9;
        --text-muted: #94a3b8;
        --text-light: #64748b;
        --border: #1e1e1e;
        --accent: #818cf8;
      }
      html {
        scroll-behavior: smooth;
        font-family: "Inter", system-ui, sans-serif;
      }
      body {
        background: var(--bg);
        color: var(--text);
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <TopBar />
    <div class="page-wrapper">
      <aside class="sidebar-left">
        <Sidebar />
      </aside>
      <main class="main-content">
        <slot />
      </main>
      <aside class="sidebar-right">
        <RightPanel />
      </aside>
    </div>
    <footer class="site-footer">
      <p>&copy; 2026 sinibaca. Built with Astro & Tailwind.</p>
    </footer>
    <style>
      /* Layout: sidebars pushed to edges, content centered */
      .page-wrapper {
        display: grid;
        grid-template-columns: 1fr minmax(0, 800px) 1fr;
        gap: 48px;
        padding: 80px 32px 40px;
        min-height: calc(100vh - 120px);
      }

      /* Left sidebar: stick to LEFT edge of its column */
      .sidebar-left {
        width: 260px;
        justify-self: start;
        position: sticky;
        top: 80px;
        height: fit-content;
        padding-left: 8px;
      }

      /* Main content: stays centered */
      .main-content {
        width: 100%;
        min-width: 0;
      }

      /* Right sidebar: stick to RIGHT edge of its column */
      .sidebar-right {
        width: 280px;
        justify-self: end;
        position: sticky;
        top: 80px;
        height: fit-content;
        padding-right: 8px;
      }

      .site-footer {
        width: 100%;
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 24px;
        color: var(--text-light);
        font-size: 0.875rem;
      }

      /* Medium screens: hide right sidebar */
      @media (max-width: 1200px) {
        .page-wrapper {
          grid-template-columns: 260px 1fr;
          gap: 32px;
        }
        .sidebar-right { display: none; }
        .sidebar-left {
          justify-self: start;
          padding-left: 0;
        }
      }

      /* Small screens: hide left sidebar, show hamburger */
      @media (max-width: 900px) {
        .page-wrapper {
          grid-template-columns: 1fr;
          padding: 60px 16px 40px;
          gap: 0;
        }
        .sidebar-left {
          display: none;
          position: fixed;
          top: 60px;
          left: 0;
          bottom: 0;
          width: 280px;
          z-index: 90;
          background: var(--bg);
          border-right: 1px solid var(--border);
          padding: 20px;
          overflow-y: auto;
          justify-self: start;
        }
        .sidebar-left.mobile-open {
          display: block;
        }
        .main-content {
          max-width: 100%;
        }
      }
    </style>
  </body>
</html>
