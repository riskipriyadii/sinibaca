---
import Sidebar from "../components/Sidebar.astro";
import RightPanel from "../components/RightPanel.astro";
import TopBar from "../components/TopBar.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "sinibaca", description = "Blog modern dengan Astro" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/sinibaca-v2/favicons/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/sinibaca-v2/favicons/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/sinibaca-v2/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/sinibaca-v2/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/sinibaca-v2/favicons/site.webmanifest" />
    
    <!-- Fallback: browser selalu cari /favicon.ico di root -->
    <link rel="icon" type="image/x-icon" href="/sinibaca-v2/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Hindari flash tema saat reload -->
    <script is:inline>
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.setAttribute("data-mode", saved);
    </script>
    
    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-secondary: #f8fafc;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --border: #f1f5f9;
        --accent: #6366f1;
      }
      html[data-mode="dark"] {
        --bg: #0a0a0a;
        --bg-secondary: #141414;
        --text: #f1f5f9;
        --text-muted: #94a3b8;
        --text-light: #64748b;
        --border: #1e1e1e;
        --accent: #818cf8;
      }
      html {
        scroll-behavior: smooth;
        font-family: "Inter", system-ui, sans-serif;
        overflow-x: hidden;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        margin: 0;
      }
    </style>
  </head>
  <body>
    <TopBar />
    <div class="page-wrapper">
      <aside class="sidebar-left">
        <Sidebar />
      </aside>
      <main class="main-content">
        <slot />
      </main>
      <aside class="sidebar-right">
        <RightPanel />
      </aside>
    </div>
    <footer class="site-footer">
      <p>&copy; 2026 sinibaca. Built with Astro & Tailwind.</p>
    </footer>
    <style>
      .page-wrapper {
        display: grid;
        grid-template-columns: 260px 1fr 260px;
        gap: 32px;
        padding: 80px 24px 40px;
        flex: 1;
        min-height: 0;
      }

      .sidebar-left,
      .sidebar-right {
        width: 100%;
      }

      .main-content {
        width: 100%;
        min-width: 0;
      }

      .site-footer {
        width: 100%;
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 0 24px;
        color: var(--text-light);
        font-size: 0.875rem;
        height: 61px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      @media (max-width: 1200px) {
        .page-wrapper {
          grid-template-columns: 260px 1fr;
          gap: 32px;
        }
        .sidebar-right { display: none; }
      }

      @media (max-width: 900px) {
        .page-wrapper {
          grid-template-columns: 1fr;
          padding: 60px 16px 40px;
          gap: 0;
        }
        .sidebar-left {
          display: none;
          position: fixed;
          top: 60px;
          left: 0;
          bottom: 0;
          width: 280px;
          z-index: 90;
          background: var(--bg);
          border-right: 1px solid var(--border);
          padding: 20px;
          overflow-y: auto;
        }
        .sidebar-left.mobile-open {
          display: block;
        }
        .main-content {
          max-width: 100%;
        }
      }
    </style>
  </body>
</html>