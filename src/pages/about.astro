---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Tentang sinibaca" description="Nulis kalau semua kondisi mendukung, dan itu jarang terjadi.">
  <div class="about-page">
    <h1>Tentang sinibaca</h1>
    
    <p class="tagline">Nulis kalau semua kondisi mendukung, dan itu jarang terjadi.</p>
    
    <div class="about-section">
      <h2>Sosial</h2>
      <a href="https://instagram.com/sinibaca" target="_blank" rel="noopener noreferrer" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        Instagram
      </a>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    max-width: 600px;
  }
  
  .about-page h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text, #0f172a);
  }
  
  .tagline {
    font-size: 1rem;
    color: var(--text-secondary, #475569);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }
  
  .about-section h2 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #94a3b8);
    margin-bottom: 0.75rem;
  }
  
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text, #0f172a);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  
  .social-link:hover {
    background: var(--bg-secondary, #f8fafc);
    color: var(--accent, #6366f1);
    border-color: var(--border, #e2e8f0);
  }
  
  .social-link svg {
    color: var(--text-muted, #94a3b8);
    transition: color 0.2s ease;
  }
  
  .social-link:hover svg {
    color: var(--accent, #6366f1);
  }
</style>