---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const postsPerPage = 1;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const base = import.meta.env.BASE_URL;
---

<Layout title="sinibaca — Blog Modern" description="Kumpulan artikel teknologi, tutorial, dan catatan pengembangan web.">
  <div class="home-header">
    <h1 class="page-title">Artikel Terbaru</h1>
    <p class="page-subtitle">{sortedPosts.length} artikel ditemukan</p>
  </div>

  <div class="posts-list" id="posts-list" data-total-pages={totalPages}>
    {sortedPosts.map((post, index) => {
      const page = Math.floor(index / postsPerPage) + 1;
      const thumb = post.data.thumbnail || (post.data.heroImage ? post.data.heroImage.src : null);
      const imageUrl = thumb 
        ? (thumb.startsWith('/') ? base + thumb.slice(1) : thumb.startsWith('http') ? thumb : base + thumb) 
        : base + 'images/placeholder.jpg';
      const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
        year: "numeric", month: "short", day: "numeric"
      });
      const slug = post.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '') || 'post';
      return (
        <div class={`post-item ${page !== 1 ? 'hidden' : ''}`} data-page={page}>
          <a href={`${base}blog/${slug}`} class="post-card">
            <div class="post-thumb-wrap">
              <img src={imageUrl} alt={post.data.title} class="post-thumb" loading="lazy" onerror="this.style.display='none'" />
            </div>
            <div class="post-body">
              <div class="post-meta">
                <span class="post-cat">{post.data.category || "Uncategorized"}</span>
                <span class="post-date">{dateStr}</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description || ""}</p>
            </div>
          </a>
        </div>
      );
    })}
  </div>

  {totalPages > 1 && (
    <div class="pagination" id="pagination">
      <div class="page-buttons">
        <button class="page-btn page-prev" id="page-prev" disabled>← Prev</button>
        {Array.from({ length: totalPages }, (_, i) => {
          const page = i + 1;
          return (
            <button class={`page-btn page-num ${page === 1 ? 'active' : ''}`} data-page={page}>
              {page}
            </button>
          );
        })}
        <button class="page-btn page-next" id="page-next">Next →</button>
      </div>
    </div>
  )}
</Layout>

<style>
  .home-header { margin-bottom: 16px; }
  .page-title { font-size: 1.5rem; font-weight: 700; margin: 0 0 6px; color: var(--text); }
  .page-subtitle { font-size: 0.9rem; color: var(--text-muted); margin: 0; }
  
  .post-card {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }
  .post-card:hover {
    border-color: var(--accent);
  }
  .post-thumb-wrap {
    width: 160px;
    height: 100px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-secondary);
  }
  .post-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    min-width: 0;
  }
  .post-meta {
    display: flex;
    gap: 12px;
    font-size: 0.8rem;
    color: var(--text-light);
  }
  .post-cat {
    font-weight: 600;
    color: var(--accent);
  }
  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: var(--text);
  }
  .post-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post-item.hidden {
    display: none;
  }

  .pagination {
    display: flex;
    justify-content: center;
    padding: 16px 0 0;
  }
  .page-buttons {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .page-btn {
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .page-btn:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .page-btn.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>

<script>
  (function() {
    const list = document.getElementById('posts-list');
    const pagination = document.getElementById('pagination');
    if (!list || !pagination) return;

    const items = list.querySelectorAll('.post-item');
    const totalPages = parseInt(list.dataset.totalPages || '1');
    let currentPage = 1;

    const prevBtn = document.getElementById('page-prev');
    const nextBtn = document.getElementById('page-next');
    const numBtns = pagination.querySelectorAll('.page-num');

    function showPage(page) {
      if (page < 1 || page > totalPages) return;
      currentPage = page;

      items.forEach(item => {
        const itemPage = parseInt(item.dataset.page);
        item.classList.toggle('hidden', itemPage !== currentPage);
      });

      numBtns.forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.page) === currentPage);
      });

      if (prevBtn) prevBtn.disabled = currentPage === 1;
      if (nextBtn) nextBtn.disabled = currentPage === totalPages;

      window.location.hash = `page-${currentPage}`;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    numBtns.forEach(btn => {
      btn.addEventListener('click', () => showPage(parseInt(btn.dataset.page)));
    });

    if (prevBtn) prevBtn.addEventListener('click', () => showPage(currentPage - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => showPage(currentPage + 1));

    const hash = window.location.hash;
    if (hash.startsWith('#page-')) {
      const p = parseInt(hash.replace('#page-', ''));
      if (p >= 1 && p <= totalPages) showPage(p);
    }
  })();
</script>