---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const postsPerPage = 5;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
---

<Layout title="sinibaca — Blog Modern" description="Kumpulan artikel teknologi, tutorial, dan catatan pengembangan web.">
  <div class="home-header">
    <h1 class="page-title">Artikel Terbaru</h1>
    <p class="page-subtitle">{sortedPosts.length} artikel ditemukan</p>
  </div>

  <div class="posts-grid" id="posts-grid" data-total-pages={totalPages}>
    {sortedPosts.map((post, index) => {
      const page = Math.floor(index / postsPerPage) + 1;
      const isHidden = page !== 1;
      return (
        <div class={`post-animate ${isHidden ? 'hidden' : ''}`} data-page={page} style={`animation-delay: ${index * 80}ms`}>
          <PostCard post={{ 
            slug: post.id, 
            data: {
              title: post.data.title,
              description: post.data.description,
              pubDate: post.data.pubDate,
              category: post.data.category,
              tags: post.data.tags,
              thumbnail: post.data.thumbnail,
              heroImage: post.data.heroImage?.src
            }
          }} />
        </div>
      );
    })}
  </div>

  {totalPages > 1 && (
    <div class="pagination" id="pagination">
      <div class="page-buttons">
        <button class="page-btn page-prev" id="page-prev" disabled>← Prev</button>
        {Array.from({ length: totalPages }, (_, i) => {
          const page = i + 1;
          return (
            <button class={`page-btn page-num ${page === 1 ? 'active' : ''}`} data-page={page}>
              {page}
            </button>
          );
        })}
        <button class="page-btn page-next" id="page-next">Next →</button>
      </div>
    </div>
  )}
</Layout>

<style>
  .home-header {
    margin-bottom: 32px;
  }
  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    color: var(--text);
  }
  .page-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
  }
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .post-animate {
    opacity: 0;
    animation: fadeSlideUp 0.5s ease forwards;
  }
  .post-animate.hidden {
    display: none;
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .pagination {
    display: flex;
    justify-content: center;
    padding: 40px 0 20px;
  }
  .page-buttons {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .page-btn {
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .page-btn:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .page-btn.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>

<script>
  (function() {
    const grid = document.getElementById('posts-grid');
    const pagination = document.getElementById('pagination');
    if (!grid || !pagination) return;

    const posts = grid.querySelectorAll('.post-animate');
    const totalPages = parseInt(grid.dataset.totalPages || '1');
    let currentPage = 1;

    const prevBtn = document.getElementById('page-prev');
    const nextBtn = document.getElementById('page-next');
    const numBtns = pagination.querySelectorAll('.page-num');

    function showPage(page) {
      if (page < 1 || page > totalPages) return;
      currentPage = page;

      posts.forEach(post => {
        const postPage = parseInt(post.dataset.page);
        post.classList.toggle('hidden', postPage !== currentPage);
      });

      numBtns.forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.page) === currentPage);
      });

      if (prevBtn) prevBtn.disabled = currentPage === 1;
      if (nextBtn) nextBtn.disabled = currentPage === totalPages;

      window.location.hash = `page-${currentPage}`;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    numBtns.forEach(btn => {
      btn.addEventListener('click', () => showPage(parseInt(btn.dataset.page)));
    });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => showPage(currentPage - 1));
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => showPage(currentPage + 1));
    }

    const hash = window.location.hash;
    if (hash.startsWith('#page-')) {
      const p = parseInt(hash.replace('#page-', ''));
      if (p >= 1 && p <= totalPages) showPage(p);
    }
  })();
</script>