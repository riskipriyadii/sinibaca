---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { countReferences } from "../utils/countReferences";

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const MONTHS_FULL = ["","Januari","Februari","Maret","April","Mei","Juni","Juli","Agustus","September","Oktober","November","Desember"];
const MONTHS_ID = ["","Jan","Feb","Mar","Apr","Mei","Jun","Jul","Agt","Sep","Okt","Nov","Des"];

const monthKeys = [...new Set(posts.map(p => {
  const d = new Date(p.data.pubDate);
  return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,"0");
}))];
---

<Layout title="Arsip — sinibaca" description={`Arsip ${posts.length} tulisan di sinibaca.`}>
  <!-- Page header -->
  <div style="margin-bottom: 1.25rem;">
    <div style="display:inline-flex; align-items:center; gap:0; margin-bottom:6px; height:27px; border-radius:8px; overflow:hidden;">
      <span style="background-color:#6366f1; color:white; font-size:0.8rem; font-weight:700; padding:4px 10px; height:100%; display:flex; align-items:center;">{posts.length}</span>
      <span style="background-color:#dc2626; color:white; font-size:0.8rem; font-weight:600; padding:4px 12px; height:100%; display:flex; align-items:center;">Tulisan</span>
    </div>
    <p style="font-size:13px; color:var(--text-muted); margin:0;">Semua tulisan, diurutkan dari yang terbaru.</p>
  </div>

  <!-- Archive list with month-year headers -->
  <div style="width:100%;">
    {monthKeys.map(mk => {
      const [yr, mo] = mk.split("-");
      const monthPosts = posts.filter(p => {
        const d = new Date(p.data.pubDate);
        return d.getFullYear() == parseInt(yr) && (d.getMonth()+1) == parseInt(mo);
      });
      
      return (
        <div style="margin-bottom:32px;">
          {/* Month-Year section header */}
          <h2 style="font-size:1.3rem; font-weight:600; color:var(--text); margin:0 0 16px 0; letter-spacing:-0.01em;">
            {MONTHS_FULL[parseInt(mo)]} {yr}
          </h2>
          
          {/* Posts in this month */}
          <div style="display:flex; flex-direction:column; gap:6px;">
            {monthPosts.map(p => {
                  const d = new Date(p.data.pubDate);
                  const rilisDateStr = String(d.getDate()).padStart(2,"0") + " " + MONTHS_ID[d.getMonth()+1];
                  const slug = p.id.split("/").pop()?.replace(/\.mdx?$/, "") || "post";
                  const refCount = countReferences(p.body || "");
                  const cat = p.data.category || "Uncategorized";
                  
                  // Compute diperbarui date if it exists and is different from pubDate
                  let diperbaruiDateStr = "";
                  if (p.data.updatedDate && p.data.updatedDate.getTime() !== p.data.pubDate.getTime()) {
                    const updatedD = new Date(p.data.updatedDate);
                    diperbaruiDateStr = String(updatedD.getDate()).padStart(2,"0") + " " + MONTHS_ID[updatedD.getMonth()+1];
                  }
                  
                  return (
                    <a
                      href={`${base}/blog/${slug}`}
                      style="display:grid; grid-template-columns:95px 1fr; grid-template-rows:repeat(3,20px); gap:4px 10px; padding:10px 12px; background:var(--card-bg); border:0.5px solid var(--border); border-radius:12px; margin-bottom:6px; text-decoration:none; cursor:pointer; transition:all 0.2s ease;"
                      class="post-card-compact"
                      data-rilis={rilisDateStr}
                      data-diperbarui={diperbaruiDateStr}
                      data-category={cat}
                      data-title={p.data.title}
                      data-ref-count={refCount}
                    >
                      {/* Row 1 Col A: Category chip */}
                      <span style="grid-row:1; align-self:center; display:inline-flex; align-items:center; gap:4px; height:20px; color:var(--accent); background:rgba(99,102,241,0.08); border:0.5px solid rgba(99,102,241,0.2); padding:0 8px; border-radius:999px; font-size:11px; font-weight:600; white-space:nowrap;">
                        <img src={`${base}/icons/icons8-diversity.gif`} alt="category" width="13" height="13" style="width:13px;height:13px;object-fit:contain;display:inline-block;" />
                        {cat}
                      </span>
                      
                      {/* Title wrapper: spans rows 1-3, column 2, uses float technique */}
                      <div class="title-wrapper" style="grid-row:1/4; grid-column:2; height:70px; overflow:hidden; font-size:15px; font-weight:700; color:var(--text); line-height:24px; word-break:break-word; white-space:normal; position:relative; top:-2px;">
                        <div style="float:right; clear:right; height:50px; width:0;"></div>
                        <span style="float:right; clear:right; display:inline-flex; align-items:center; gap:4px; height:20px; font-size:11px; font-weight:500; color:var(--text-muted); background:var(--bg-secondary); border:0.5px solid var(--border); padding:0 8px; border-radius:999px; white-space:nowrap; line-height:20px;">
                          <img src={`${base}/icons/ref-icon.png`} alt="ref" width="13" height="13" style="width:13px;height:13px;object-fit:contain;display:inline-block;" />
                          {refCount} referensi
                        </span>
                        {p.data.title}
                      </div>
                      
                      {/* Row 2 Col A: Diperbarui badge */}
                      {diperbaruiDateStr && (
                        <span style="grid-row:2; align-self:center; display:inline-flex; align-items:center; gap:4px; height:20px; background:#dcfce7; color:#14532d; font-size:11px; font-weight:500; padding:0 8px; border-radius:999px; border:0.5px solid #86efac; white-space:nowrap;">
                          <img src={`${base}/icons/icons8-diperbarui.gif`} alt="diperbarui" width="14" height="14" style="width:14px;height:14px;object-fit:contain;display:inline-block;" />
                          {diperbaruiDateStr}
                        </span>
                      )}
                      
                      {/* Row 3 Col A: Rilis badge */}
                      <span style="grid-row:3; align-self:center; display:inline-flex; align-items:center; gap:4px; height:20px; background:#dbeafe; color:#1e3a8a; font-size:11px; font-weight:500; padding:0 8px; border-radius:999px; border:0.5px solid #93c5fd; white-space:nowrap;">
                        <img src={`${base}/icons/icons8-rilis.png`} alt="rilis" width="14" height="14" style="width:14px;height:14px;object-fit:contain;display:inline-block;" />
                        {rilisDateStr}
                      </span>
                      
                    </a>
                  );
            })}
          </div>
        </div>
      );
    })}
  </div>
</Layout>

<style>
  .post-card-compact:hover {
    border-color: var(--accent) !important;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(99,102,241,0.08);
  }
  
  .post-card-compact:hover span:last-child {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    /* Reduce gap on mobile for tighter layout */
    .post-card-compact {
      gap: 4px !important;
      padding: 8px 10px !important;
    }
    
    /* Make title wrap on mobile instead of ellipsis */
    .post-card-compact span[style*="text-overflow: ellipsis"] {
      overflow: visible !important;
      text-overflow: clip !important;
      white-space: normal !important;
    }
  }
</style>
