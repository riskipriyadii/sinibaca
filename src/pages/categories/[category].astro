---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { sortByLatestDate } from "../../utils/date-helpers";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  
  const categories = new Set<string>();
  posts.forEach((post) => {
    const cat = post.data.category || "Uncategorized";
    categories.add(cat);
  });

  return Array.from(categories).map((category) => ({
    params: { category },
    props: {
      posts: posts.filter((post) => (post.data.category || "Uncategorized") === category),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = sortByLatestDate(posts);
---

<Layout title={`Kategori: ${category} — sinibaca`} description={`Artikel dengan kategori ${category}`}>
  <div class="home-header">
    <h1 class="page-title">Kategori: {category}</h1>
    <p class="page-subtitle">{sortedPosts.length} artikel ditemukan</p>
  </div>

  <div class="posts-list">
    {sortedPosts.map((post) => (
      <div class="post-item">
        <PostCard post={post} />
      </div>
    ))}
  </div>
</Layout>

<style>
  .home-header {
    text-align: center;
    margin-bottom: 48px;
    animation: fadeInUp 0.6s ease;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: var(--text);
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin: 0;
  }
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .post-item {
    animation: fadeInUp 0.5s ease;
    animation-fill-mode: both;
  }
</style>