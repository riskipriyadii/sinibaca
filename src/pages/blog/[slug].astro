---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Giscus from "../../components/Giscus.astro";
import TableOfContentsOverlay from "../../components/TableOfContentsOverlay.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => {
    const slug = post.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '') || 'post';
    return {
      params: { slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

function getImageUrl(thumbnail?: string, heroImage?: string | { src: string }): string {
  const placeholder = `${base}images/placeholder.jpg`;
  let src: string | undefined;
  
  if (thumbnail) {
    src = thumbnail;
  } else if (heroImage) {
    src = typeof heroImage === 'string' ? heroImage : heroImage.src;
  }
  
  if (!src) return placeholder;
  if (src.startsWith("http")) return src;
  if (src.startsWith("/")) return base + src.slice(1);
  return base + src;
}

const imageUrl = getImageUrl(post.data.thumbnail, post.data.heroImage);
const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
  year: "numeric", month: "long", day: "numeric"
});
---

<Layout title={post.data.title} description={post.data.description || ""} noScroll={true}>
  <TableOfContentsOverlay />
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta" style="padding-left: 4px; overflow: visible;">
        <a href={`${base}categories/${post.data.category || 'Uncategorized'}`} class="category">{post.data.category || "Uncategorized"}</a>
        <span class="date">{dateStr}</span>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="post-description">{post.data.description}</p>
      )}
      <div class="post-tags" style="padding-left: 4px; overflow: visible;">
        {(post.data.tags || []).map((tag) => (
          <a href={`${base}tags/${tag}`} class="tag">#{tag}</a>
        ))}
      </div>
    </header>
    <img src={imageUrl} alt={post.data.title} class="hero-image" onerror={`this.src='${base}images/placeholder.jpg'`} />
    <div class="post-content">
      <Content />
    </div>
  </article>
  <Giscus />
</Layout>

<style>
  .blog-post {
    animation: fadeInUp 0.5s ease;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .post-header {
    margin-bottom: 32px;
    overflow: visible;
  }
  .post-meta {
    display: flex;
    gap: 16px;
    font-size: 0.875rem;
    color: var(--text-light);
    margin-bottom: 16px;
  }
  .category {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .category:hover {
    background: var(--accent);
    color: white;
    transform: scale(1.05);
  }
  .date {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .date:hover {
    background: var(--accent);
    color: white;
    transform: scale(1.05);
  }
  .post-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 16px;
    color: var(--text);
  }
  .post-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 20px;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .tag:hover {
    background: var(--accent);
    color: white;
    transform: scale(1.05);
  }
  .hero-image {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 40px;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }
  /* 🔧 FIX: sembunyikan h1 duplikat dari body markdown */
  .post-content :global(h1:first-of-type) {
    display: none;
  }
  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .post-content :global(p) {
    margin-bottom: 20px;
  }
  .post-content :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  .post-content :global(code) {
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 0.9em;
  }
  .post-content :global(img) {
    border-radius: 12px;
    max-width: 100%;
    height: auto;
  }
  .post-content :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding-left: 20px;
    margin-left: 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .post-content :global(li) {
    margin-bottom: 8px;
  }
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
</style>