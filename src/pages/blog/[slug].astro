---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Giscus from "../../components/Giscus.astro";
import TableOfContentsOverlay from "../../components/TableOfContentsOverlay.astro";
import { countReferences } from "../../utils/countReferences";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  
  // Build category color mapping (same as RightPanel.astro)
  const categoryColorPalette = [
    { bg: '#6B8FD4', text: '#FFFFFF', dark: '#6B8FD4' }, // Filsafat - Blue
    { bg: '#52B788', text: '#FFFFFF', dark: '#52B788' }, // Arsitektur - Green
    { bg: '#fecaca', text: '#991b1b', dark: '#fca5a5' }, // Red
    { bg: '#a7f3d0', text: '#065f46', dark: '#6ee7b7' }, // Green
    { bg: '#bfdbfe', text: '#1e40af', dark: '#93c5fd' }, // Blue
    { bg: '#fbcfe8', text: '#9f1239', dark: '#f9a8d4' }, // Pink
    { bg: '#fed7aa', text: '#9a3412', dark: '#fdba74' }, // Orange
    { bg: '#d1fae5', text: '#065f46', dark: '#a7f3d0' }, // Mint
  ];
  
  const categoryCounts: Record<string, number> = {};
  posts.forEach((post) => {
    const cat = post.data.category || "Uncategorized";
    categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
  });
  const categories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]);
  
  const categoryColorMap: Record<string, typeof categoryColorPalette[0]> = {};
  categories.forEach(([cat], index) => {
    categoryColorMap[cat] = categoryColorPalette[index % categoryColorPalette.length];
  });
  
  return posts.map((post) => {
    const slug = post.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '') || 'post';
    const category = post.data.category || "Uncategorized";
    const categoryColor = categoryColorMap[category];
    return {
      params: { slug },
      props: { post, categoryColor },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
  categoryColor: { bg: string; text: string; dark: string };
}

const { post, categoryColor } = Astro.props;
const { Content } = await render(post);

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const refCount = countReferences(post.body || "");

function getImageUrl(thumbnail?: string, heroImage?: string | { src: string }): string {
  const placeholder = `${base}images/placeholder.jpg`;
  let src: string | undefined;
  
  if (thumbnail) {
    src = thumbnail;
  } else if (heroImage) {
    src = typeof heroImage === 'string' ? heroImage : heroImage.src;
  }
  
  if (!src) return placeholder;
  if (src.startsWith("http")) return src;
  if (src.startsWith("/")) return base + src.slice(1);
  return base + src;
}

const imageUrl = getImageUrl(post.data.thumbnail, post.data.heroImage);
const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
  year: "numeric", month: "long", day: "numeric"
});

const updatedDateStr = post.data.updatedDate ? post.data.updatedDate.toLocaleDateString("id-ID", {
  day: "numeric", month: "short", year: "numeric",
}) : null;

const showUpdated = post.data.updatedDate && post.data.updatedDate.getTime() !== post.data.pubDate.getTime();
---

<Layout title={post.data.title} description={post.data.description || ""}>
  <TableOfContentsOverlay />
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta" style="padding-left: 4px; overflow: visible;">
        <a 
          href={`${base}categories/${post.data.category || 'Uncategorized'}`} 
          class="category"
          style={`background: ${categoryColor.bg}; color: ${categoryColor.text};`}
        >{post.data.category || "Uncategorized"}</a>
        <span class="rilis-pill">
          <span class="rilis-badge">Rilis</span>
          <span class="rilis-date">{dateStr}</span>
        </span>
        {showUpdated && (
          <span class="updated-pill">
            <span class="updated-badge">Diperbarui</span>
            <span class="updated-date">{updatedDateStr}</span>
          </span>
        )}
        {refCount > 0 && (
          <button class="ref-badge" data-scroll-to="referensi" aria-label="Gulir ke bagian Referensi">
            <img src={`${base}icons/ref-icon.png`} alt="referensi" width="16" height="16" style="width:16px;height:16px;object-fit:contain;display:inline-block;" />
            {refCount} referensi
          </button>
        )}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="post-description">{post.data.description}</p>
      )}
      <div class="post-tags" style="padding-left: 4px; overflow: visible;">
        {(post.data.tags || []).map((tag) => (
          <a href={`${base}tags/${tag}`} class="tag">#{tag}</a>
        ))}
      </div>
    </header>
    <img src={imageUrl} alt={post.data.title} class="hero-image" onerror={`this.src='${base}images/placeholder.jpg'`} />
    <div class="post-content">
      <Content />
      <Giscus />
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    animation: fadeInUp 0.5s ease;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .post-header {
    margin-bottom: 32px;
    overflow: visible;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.875rem;
    color: var(--text-light);
    margin-bottom: 16px;
    align-items: center;
  }
  .category {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.8rem;
    text-decoration: none;
    flex-shrink: 0;
    transition: all 0.15s ease;
    cursor: pointer;
    font-weight: 600;
  }
  .category:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
  }
  :global(.dark) .category {
    filter: brightness(0.85);
  }
  :global(.dark) .category:hover {
    filter: brightness(1);
  }
  .rilis-pill {
    display: inline-flex;
    align-items: center;
    height: 24px;
    border-radius: 999px;
    overflow: hidden;
    font-size: 0.72rem;
    flex-shrink: 0;
    cursor: pointer;
  }
  .rilis-pill:hover {
    transform: scale(1.05);
  }
  .rilis-badge {
    display: flex;
    align-items: center;
    height: 100%;
    background: #eff6ff;
    color: #1d4ed8;
    font-weight: 700;
    padding: 0 0.65rem;
    transition: all 0.15s ease;
  }
  .rilis-pill:hover .rilis-badge {
    background: #2563eb;
    color: white;
  }
  .rilis-date {
    display: flex;
    align-items: center;
    height: 100%;
    background: #dbeafe;
    color: #1e3a8a;
    font-weight: 500;
    padding: 0 0.65rem;
    transition: all 0.15s ease;
  }
  .rilis-pill:hover .rilis-date {
    background: #2563eb;
    color: white;
  }
  .updated-pill {
    display: inline-flex;
    align-items: center;
    height: 24px;
    border-radius: 999px;
    overflow: hidden;
    font-size: 0.72rem;
    flex-shrink: 0;
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .updated-pill:hover {
    transform: scale(1.05);
  }
  .updated-badge {
    display: flex;
    align-items: center;
    height: 100%;
    background: #f0fdf4;
    color: #15803d;
    font-weight: 700;
    padding: 0 0.65rem;
    transition: all 0.15s ease;
  }
  .updated-pill:hover .updated-badge {
    background: #16a34a;
    color: white;
  }
  .updated-date {
    display: flex;
    align-items: center;
    height: 100%;
    background: #dcfce7;
    color: #14532d;
    font-weight: 500;
    padding: 0 0.65rem;
    transition: all 0.15s ease;
  }
  .updated-pill:hover .updated-date {
    background: #16a34a;
    color: white;
  }
  .ref-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 28px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 0.75rem;
    flex-shrink: 0;
    transition: all 0.15s ease;
    cursor: pointer;
    border: none;
    font-family: inherit;
    outline: none;
  }
  .ref-badge:hover {
    background: var(--accent);
    color: white;
    transform: scale(1.05);
  }
  .ref-badge:focus {
    outline: none;
  }
  .ref-badge:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .ref-badge:active {
    transform: scale(0.98);
  }
  /* Dark mode styles for updated pill */
  :global(.dark) .updated-badge {
    background: #14532d;
    color: #bbf7d0;
  }
  :global(.dark) .updated-date {
    background: #166534;
    color: #dcfce7;
  }
  :global(.dark) .updated-pill:hover .updated-badge,
  :global(.dark) .updated-pill:hover .updated-date {
    background: #16a34a;
    color: white;
  }
  .post-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 16px;
    color: var(--text);
  }
  .post-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 20px;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .tag:hover {
    background: var(--accent);
    color: white;
    transform: scale(1.05);
  }
  .hero-image {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 40px;
    aspect-ratio: 16/9;
    object-fit: contain;
    background: white;
  }
  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }
  /* 🔧 FIX: sembunyikan h1 duplikat dari body markdown */
  .post-content :global(h1:first-of-type) {
    display: none;
  }
  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .post-content :global(p) {
    margin-bottom: 20px;
  }
  .post-content :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  .post-content :global(code) {
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 0.9em;
  }
  .post-content :global(img) {
    border-radius: 12px;
    max-width: 100%;
    height: auto;
  }
  .post-content :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding-left: 20px;
    margin-left: 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .post-content :global(li) {
    margin-bottom: 8px;
  }
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  
  /* Scroll margin for headings to account for any fixed elements */
  .post-content :global(h2),
  .post-content :global(h3) {
    scroll-margin-top: 80px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const refBadge = document.querySelector('.ref-badge[data-scroll-to]');
    
    if (refBadge) {
      refBadge.addEventListener('click', () => {
        const targetId = refBadge.getAttribute('data-scroll-to');
        const targetElement = document.getElementById(targetId || '');
        
        if (targetElement) {
          targetElement.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
          });
        }
      });
    }
  });
</script>
