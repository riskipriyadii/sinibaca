---
import { getCollection } from "astro:content";
import avatarImg from "../assets/avatar.png";
import Newsletter from "./Newsletter.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const categoryCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  const cat = post.data.category || "Uncategorized";
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
});
const categories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]);

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const navItems = [
  { label: "Beranda", href: `${base}` },
  { label: "Tentang", href: `${base}about` },
];

const socials = [
  { 
    label: "Instagram", 
    href: "https://www.instagram.com/ronin.monetaro/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`
  },
];
---

<div class="sidebar">
  <div class="profile-card">
    <div class="avatar-wrap">
      <div class="avatar-ring avatar-ring--wave"></div>
      <img src={avatarImg.src} alt="sinibaca" class="avatar" width="72" height="72" />
    </div>
    <h3 class="name">sinibaca</h3>
    <p class="bio">Nulis kalau semua kondisi mendukung, dan itu jarang terjadi.</p>
    <div class="stats">
      <div class="stat"><span class="stat-val">{allPosts.length}</span><span class="stat-lbl">Artikel</span></div>
      <div class="stat"><span class="stat-val">{Object.keys(categoryCounts).length}</span><span class="stat-lbl">Kategori</span></div>
    </div>
  </div>

  <div class="section-card">
    <h4 class="section-title">Navigasi</h4>
    <nav class="nav-list">
      {navItems.map((item) => (
        <a href={item.href} class="nav-item">{item.label}</a>
      ))}
    </nav>
  </div>

  <div class="section-card">
    <h4 class="section-title">Kategori</h4>
    <div class="cat-list">
      {categories.map(([cat, count]) => (
        <a href={`${base}blog`} class="cat-item">
          <span>{cat}</span>
          <span class="badge">{count}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="section-card">
    <h4 class="section-title">Sosial</h4>
    <div class="social-list">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" class="social-item">
          <span class="social-icon" set:html={s.icon}></span>
          {s.label}
        </a>
      ))}
    </div>
  </div>

  <Newsletter />

  <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
    Mode Gelap
  </button>
</div>

<script>
  const toggle = document.getElementById("theme-toggle");
  const html = document.documentElement;
  toggle?.addEventListener("click", () => {
    const isDark = html.getAttribute("data-mode") === "dark";
    const newMode = isDark ? "light" : "dark";
    html.setAttribute("data-mode", newMode);
    localStorage.setItem("theme", newMode);
  });
</script>

<style>
  .sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .profile-card { background: var(--card-bg, #f9f9f9); border: 1px solid var(--border, #e5e7eb); border-radius: 12px; padding: 1.25rem; text-align: center; }
  
  /* ============================================
     AVATAR WRAPPER — base positioning
     ============================================ */
  .avatar-wrap {
    position: relative;
    width: fit-content;
    margin: 0 auto 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar {
    position: relative;
    z-index: 2;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: block;
    border: 3px solid var(--accent, #6366f1);
  }

  /* ============================================
     BASE — Dashed Diamond Ring
     ============================================ */
  .avatar-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 88px;
    height: 88px;
    border: 2px dashed #a5d8ff;
    border-radius: 14px;
    transform: translate(-50%, -50%) rotate(45deg);
    z-index: 1;
    pointer-events: none;
    opacity: 0.75;
  }

  /* ============================================
     VARIASI 1: Dashed Wave (default)
     Berputar + bergelombang (scale + border-radius morph)
     ============================================ */
  .avatar-ring--wave {
    animation: dashedWave 10s linear infinite;
  }

  @keyframes dashedWave {
    0% {
      transform: translate(-50%, -50%) rotate(45deg) scale(1);
      border-radius: 14px;
      opacity: 0.75;
    }
    25% {
      transform: translate(-50%, -50%) rotate(135deg) scale(1.06);
      border-radius: 26px;
      opacity: 0.5;
    }
    50% {
      transform: translate(-50%, -50%) rotate(225deg) scale(1);
      border-radius: 14px;
      opacity: 0.75;
    }
    75% {
      transform: translate(-50%, -50%) rotate(315deg) scale(1.06);
      border-radius: 26px;
      opacity: 0.5;
    }
    100% {
      transform: translate(-50%, -50%) rotate(405deg) scale(1);
      border-radius: 14px;
      opacity: 0.75;
    }
  }

  /* ============================================
     VARIASI 2: Dual Dashed Counter
     2 ring putus-putus berputar berlawanan arah
     Tambahkan sibling di HTML:
       <div class="avatar-ring avatar-ring--counter"></div>
       <div class="avatar-ring-outer"></div>
     ============================================ */
  .avatar-ring--counter {
    animation: dashedSpin 12s linear infinite;
  }

  .avatar-ring-outer {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100px;
    height: 100px;
    border: 1.5px dashed rgba(165, 216, 255, 0.5);
    border-radius: 18px;
    transform: translate(-50%, -50%) rotate(45deg);
    z-index: 0;
    pointer-events: none;
    animation: dashedSpinReverse 12s linear infinite;
  }

  @keyframes dashedSpin {
    from { transform: translate(-50%, -50%) rotate(45deg); }
    to   { transform: translate(-50%, -50%) rotate(405deg); }
  }

  @keyframes dashedSpinReverse {
    from { transform: translate(-50%, -50%) rotate(45deg); }
    to   { transform: translate(-50%, -50%) rotate(-315deg); }
  }

  /* ============================================
     VARIASI 3: Dashed Breathe
     Berputar lambat + napas halus (scale + opacity)
     Ganti class: avatar-ring--breathe
     ============================================ */
  .avatar-ring--breathe {
    animation: dashedBreathe 20s ease-in-out infinite;
  }

  @keyframes dashedBreathe {
    0%, 100% {
      transform: translate(-50%, -50%) rotate(45deg) scale(1);
      border-radius: 14px;
      opacity: 0.4;
      border-width: 2px;
    }
    50% {
      transform: translate(-50%, -50%) rotate(225deg) scale(1.12);
      border-radius: 22px;
      opacity: 0.85;
      border-width: 3px;
    }
  }

  .name { font-size: 1rem; font-weight: 700; margin: 0 0 0.25rem; }
  .bio { font-size: 0.75rem; color: var(--muted, #6b7280); margin: 0 0 0.75rem; }
  .stats { display: flex; justify-content: center; gap: 1.5rem; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-val { font-size: 1.1rem; font-weight: 700; color: var(--accent, #6366f1); }
  .stat-lbl { font-size: 0.7rem; color: var(--muted, #6b7280); }
  .section-card { background: var(--card-bg, #f9f9f9); border: 1px solid var(--border, #e5e7eb); border-radius: 12px; padding: 1rem; }
  .section-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted, #9ca3af); margin: 0 0 0.6rem; }
  .nav-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .nav-item { display: block; padding: 0.4rem 0.6rem; border-radius: 8px; font-size: 0.875rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .nav-item:hover { background: var(--hover, #f3f4f6); }
  .cat-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .cat-item { display: flex; justify-content: space-between; align-items: center; padding: 0.35rem 0.6rem; border-radius: 8px; font-size: 0.85rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .cat-item:hover { background: var(--hover, #f3f4f6); }
  .badge { background: var(--accent, #6366f1); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 999px; }
  .social-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .social-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.35rem 0.75rem; border: 1px solid var(--border, #e5e7eb); border-radius: 999px; font-size: 0.8rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .social-item:hover { background: var(--hover, #f3f4f6); }
  .social-icon { display: flex; align-items: center; }
  .theme-toggle { 
    width: 100%; 
    padding: 0.5rem; 
    border: 1px solid var(--border); 
    border-radius: 8px; 
    background: var(--bg-secondary); 
    cursor: pointer; 
    font-size: 0.85rem; 
    transition: all 0.15s; 
    color: var(--text);
  }
  .theme-toggle:hover { 
    background: var(--hover); 
    border-color: var(--accent);
  }
</style>