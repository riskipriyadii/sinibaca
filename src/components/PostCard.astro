---
interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description?: string;
      pubDate: Date;
      category?: string;
      tags?: string[];
      thumbnail?: string;
      heroImage?: string;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { data, slug, body } = post;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getImageUrl(thumbnail?: string, heroImage?: string): string {
  const placeholder = `${base}/images/placeholder.jpg`;
  const src = thumbnail || heroImage;
  if (!src) return placeholder;
  if (src.startsWith("http")) return src;
  if (src.startsWith("/")) return `${base}${src}`;
  return `${base}/${src}`;
}

const imageUrl = getImageUrl(data.thumbnail, data.heroImage);

const dateStr = data.pubDate.toLocaleDateString("id-ID", {
  day: "numeric", month: "short", year: "numeric",
});

// Estimasi waktu baca: ~200 kata per menit
const wordCount = (body || "").split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<a href={`${base}/blog/${slug}`} class="post-card">
  <div class="thumb-wrap">
    <img src={imageUrl} alt={data.title} loading="lazy" class="thumb-img" onerror={`this.src='${base}/images/placeholder.jpg'`} />
  </div>
  <div class="card-body">
    <div class="card-meta">
      <span class="category">{data.category || "Uncategorized"}</span>
      <span class="dot">•</span>
      <span class="date">{dateStr}</span>
      <span class="dot">•</span>
      <span class="read-time">{readTime} min baca</span>
    </div>
    <h2 class="card-title">{data.title}</h2>
    <p class="card-excerpt">{data.description || ""}</p>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }
  .post-card:hover {
    background: var(--bg-secondary);
  }

  .thumb-wrap {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-secondary);
  }
  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--text-light);
    margin-bottom: 2px;
  }
  .category {
    font-weight: 600;
    color: var(--accent);
    text-transform: capitalize;
  }
  .dot {
    color: var(--text-light);
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .card-excerpt {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>