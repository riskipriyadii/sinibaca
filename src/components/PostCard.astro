---
import { countReferences } from "../utils/countReferences";

interface Props {
  post: {
    slug?: string;
    id?: string;
    data: {
      title: string;
      description?: string;
      pubDate: Date;
      updatedDate?: Date;
      category?: string;
      tags?: string[];
      thumbnail?: string;
      heroImage?: string | { src: string };
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { data, body } = post;
const slug = post.slug || (post.id ? post.id.split("/").pop()?.replace(/\.mdx?$/, "") : "") || "post";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const refCount = countReferences(body || "");

function formatDateIndonesian(date: Date) {
  return new Intl.DateTimeFormat("id-ID", { day: "numeric", month: "short", year: "numeric" }).format(date);
}

function getImageUrl(thumbnail?: string, heroImage?: string | { src: string }): string {
  const placeholder = `${base}/images/placeholder.jpg`;
  const heroSrc = typeof heroImage === "object" ? heroImage.src : heroImage;
  const src = thumbnail || heroSrc;
  if (!src) return placeholder;
  if (src.startsWith("http")) return src;
  if (src.startsWith("/")) return `${base}${src}`;
  return `${base}/${src}`;
}

const imageUrl = getImageUrl(data.thumbnail, data.heroImage);

const dateStr = data.pubDate.toLocaleDateString("id-ID", {
  day: "numeric", month: "short", year: "numeric",
});

const updatedDateStr = data.updatedDate ? data.updatedDate.toLocaleDateString("id-ID", {
  day: "numeric", month: "short", year: "numeric",
}) : null;

const showUpdated = data.updatedDate && data.updatedDate.getTime() !== data.pubDate.getTime();

const wordCount = (body || "").split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<a href={`${base}/blog/${slug}`} class="post-card">
  <div class="thumb-wrap">
    <img src={imageUrl} alt={data.title} loading="lazy" class="thumb-img" onerror={`this.src="${base}/images/placeholder.jpg"`} />
  </div>
  <div class="card-body">
    <div class="card-meta">
      <span class="category">{data.category || "Uncategorized"}</span>
      {showUpdated && (
        <span class="updated-pill">
          <span class="updated-badge">Diperbarui</span>
          <span class="updated-date">{updatedDateStr}</span>
        </span>
      )}
      <span class="dot">•</span>
      <span class="read-time">{readTime} min baca</span>
    </div>
    <h2 class="card-title">{data.title}</h2>
    <p class="card-excerpt">{data.description || ""}</p>
    <div class="card-footer-row">
      {refCount > 0 && (
        <div class="ref-badge">
          📚 {refCount} referensi
        </div>
      )}
      <span class="rilis-pill">
        <span class="rilis-badge">Rilis</span>
        <span class="rilis-date">{dateStr}</span>
      </span>
    </div>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    overflow: visible;
  }
  .post-card:hover {
    background: var(--bg-secondary);
  }

  .thumb-wrap {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-secondary);
  }
  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: visible;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--text-light);
    margin-bottom: 2px;
    flex-wrap: wrap;
  }
  .category {
    display: inline-flex;
    align-items: center;
    height: 28px;
    font-weight: 600;
    color: var(--accent);
    text-transform: capitalize;
    flex-shrink: 0;
    box-sizing: border-box;
  }
  .updated-pill {
    display: inline-flex;
    align-items: center;
    height: 24px;
    border-radius: 999px;
    overflow: hidden;
    font-size: 0.72rem;
    flex-shrink: 0;
  }
  .updated-badge {
    display: flex;
    align-items: center;
    height: 100%;
    background: #f0fdf4;
    color: #15803d;
    font-weight: 700;
    padding: 0 0.65rem;
  }
  .updated-date {
    display: flex;
    align-items: center;
    height: 100%;
    background: #dcfce7;
    color: #14532d;
    font-weight: 500;
    padding: 0 0.65rem;
  }
  .rilis-pill {
    display: inline-flex;
    align-items: center;
    height: 24px;
    border-radius: 999px;
    overflow: hidden;
    font-size: 0.72rem;
    flex-shrink: 0;
  }
  .rilis-badge {
    display: flex;
    align-items: center;
    height: 100%;
    background: #eff6ff;
    color: #1d4ed8;
    font-weight: 700;
    padding: 0 0.65rem;
  }
  .rilis-date {
    display: flex;
    align-items: center;
    height: 100%;
    background: #dbeafe;
    color: #1e3a8a;
    font-weight: 500;
    padding: 0 0.65rem;
  }
  .card-footer-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .dot {
    color: var(--text-light);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }

  .card-excerpt {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }

  .ref-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 28px;
    font-size: 0.75rem;
    color: var(--text-light);
    box-sizing: border-box;
  }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
      gap: 12px;
      padding: 14px 0;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .thumb-wrap {
      width: 100%;
      height: 180px;
    }
    .card-body {
      width: 100%;
    }
    .card-title {
      font-size: 0.98rem;
      line-height: 1.4;
    }
    .card-excerpt {
      font-size: 0.84rem;
      -webkit-line-clamp: 3;
    }
    .card-meta {
      font-size: 0.72rem;
      gap: 5px;
    }
  }

  @media (max-width: 480px) {
    .post-card {
      padding: 12px 0;
      gap: 10px;
    }
    .thumb-wrap {
      height: 160px;
    }
    .card-title {
      font-size: 0.95rem;
    }
    .card-excerpt {
      font-size: 0.82rem;
    }
    .card-meta {
      font-size: 0.7rem;
      gap: 4px;
    }
  }

  @media (max-width: 360px) {
    .thumb-wrap {
      height: 140px;
    }
    .card-title {
      font-size: 0.9rem;
    }
    .card-excerpt {
      font-size: 0.8rem;
    }
  }
</style>
