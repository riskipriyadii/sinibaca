---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<div class="newsletter-card">
  <div class="header">
    <div class="icon">
      <img src={`${base}bookmark-icon.png`} alt="Bookmark" width="32" height="32" />
    </div>
    <div>
      <h4 class="newsletter-title">Kabar Rilis Tulisan</h4>
      <p class="newsletter-subtitle">Bisa ikuti di</p>
    </div>
  </div>
  
  <a href="https://www.instagram.com/ronin.monetaro/" target="_blank" rel="noopener noreferrer" class="instagram-button">
    <img src={`${base}instagram-icon.png`} alt="Instagram" class="instagram-icon" width="24" height="24" />
    <span>@ronin.monetaro</span>
  </a>
</div>

<style>
  .newsletter-card {
    background: linear-gradient(135deg, #e9e4f7 0%, #f5f3ff 100%);
    border: 1px solid #d8d0f0;
    border-radius: 16px;
    padding: 1.5rem;
    color: #1e1b4b;
  }
  
  .header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  
  .icon {
    font-size: 2rem;
    background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .newsletter-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: #1e1b4b;
  }
  
  .newsletter-subtitle {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0;
  }
  
  .newsletter-text {
    font-size: 0.875rem;
    color: #4c1d95;
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  
  .instagram-button {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid #d8d0f0;
    border-radius: 10px;
    text-decoration: none;
    color: #1e1b4b;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.2s;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  .instagram-button span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  
  .instagram-button:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(139, 92, 246, 0.15);
    border-color: #8b5cf6;
  }
  
  .instagram-icon {
    flex-shrink: 0;
  }

  @media (prefers-color-scheme: dark) {
    .newsletter-card {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
      border-color: rgba(139, 92, 246, 0.3);
      color: #e9e4f7;
    }
    
    .newsletter-title {
      color: #e9e4f7;
    }
    
    .newsletter-text {
      color: #c4b5fd;
    }
    
    .instagram-button {
      background: rgba(139, 92, 246, 0.15);
      border-color: rgba(139, 92, 246, 0.3);
      color: #e9e4f7;
    }
    
    .instagram-button:hover {
      background: rgba(139, 92, 246, 0.25);
      border-color: #8b5cf6;
    }
  }
</style>