---
// Giscus comment component
---
<section class="giscus-section">
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="riskiipriyadi/sinibaca-v2"
    data-repo-id="R_kgDOS4GT7Q"
    data-category="Announcements"
    data-category-id="DIC_kwDOS4GT7c4C_QMI"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="preferred_color_scheme"
    data-lang="id"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .giscus-section {
    width: 100%;
    margin-top: 40px;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
  }

  /* Target the Giscus container that gets injected */
  .giscus-section :global(.giscus) {
    width: 100%;
  }

  /* Target the iframe directly */
  .giscus-section :global(.giscus-frame) {
    width: 100% !important;
    display: block;
    border: none !important;
  }

  /* Additional specificity for the iframe element */
  .giscus-section :global(iframe.giscus-frame) {
    width: 100% !important;
    max-width: 100% !important;
    border: none !important;
  }
</style>
