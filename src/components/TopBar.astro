---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = await getCollection("blog", ({ data }) => !data.draft);
const postsData = posts.map(p => ({
  title: p.data.title,
  slug: p.id,
  description: p.data.description || "",
  category: p.data.category || "Uncategorized",
  pubDate: p.data.pubDate ? new Date(p.data.pubDate).toISOString() : ""
}));
---

<header class="topbar">
  <div class="topbar-inner">
    <a href={`${base}/`} class="logo">
      <img src={`${base}/favicons/favicon-32x32.png`} alt="sinibaca" class="logo-img" width="28" height="28" />
      <span class="logo-text">sinibaca</span>
    </a>

    <div class="search-bar" data-posts={JSON.stringify(postsData)}>
      <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" placeholder="Cari tulisan.." class="search-input" id="search-input" autocomplete="off" />
        <button type="button" class="search-btn" id="search-btn">Cari</button>
      </div>
      <div class="search-dropdown" id="search-dropdown">
        <ul class="search-list" id="search-list"></ul>
        <div class="search-empty" id="search-empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <div>Tidak ada hasil ditemukan</div>
        </div>
      </div>
    </div>

    <div class="post-count">
      <span class="post-count-badge">{posts.length}</span>
      <span class="post-count-pill">Tulisan</span>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const sidebar = document.querySelector(".sidebar-left");
  toggle?.addEventListener("click", () => {
    sidebar?.classList.toggle("mobile-open");
  });

  const searchBar = document.querySelector('.search-bar');
  const searchInput = document.getElementById('search-input');
  const searchDropdown = document.getElementById('search-dropdown');
  const searchList = document.getElementById('search-list');
  const searchEmpty = document.getElementById('search-empty');
  const searchBtn = document.getElementById('search-btn');

  if (searchBar && searchInput && searchDropdown && searchList && searchEmpty) {
    const posts = JSON.parse(searchBar.dataset.posts || '[]');
    const base = window.location.pathname.startsWith('/sinibaca-v2') ? '/sinibaca-v2' : '';

    function formatDate(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function renderResults(results) {
      searchList.innerHTML = '';

      if (results.length === 0) {
        searchEmpty.style.display = 'flex';
        return;
      }

      searchEmpty.style.display = 'none';

      results.slice(0, 8).forEach(post => {
        const li = document.createElement('li');
        li.className = 'search-item';
        li.innerHTML = `
          <a href="${base}/blog/${post.slug}" class="search-result-item">
            <div class="search-meta">
              <span class="search-title">${escapeHtml(post.title)}</span>
              ${post.description ? `<span class="search-desc">${escapeHtml(post.description)}</span>` : ''}
            </div>
            <time class="search-time">${formatDate(post.pubDate)}</time>
          </a>
        `;
        searchList.appendChild(li);
      });
    }

    function filterPosts(query) {
      const q = query.toLowerCase().trim();
      if (!q) return posts.slice(0, 8);
      return posts.filter(post =>
        post.title.toLowerCase().includes(q) ||
        post.description.toLowerCase().includes(q) ||
        post.category.toLowerCase().includes(q)
      ).slice(0, 8);
    }

    // SAAT FOCUS: langsung tampilkan semua artikel (8 terbaru)
    searchInput.addEventListener('focus', () => {
      const filtered = filterPosts(searchInput.value);
      renderResults(filtered);
      searchDropdown.classList.add('active');
    });

    // SAAT MENGETIK: filter real-time
    searchInput.addEventListener('input', () => {
      const filtered = filterPosts(searchInput.value);
      renderResults(filtered);
      searchDropdown.classList.add('active');
    });

    // TOMBOL CARI: buka hasil pertama
    searchBtn?.addEventListener('click', () => {
      const firstLink = searchList.querySelector('a');
      if (firstLink) firstLink.click();
    });

    // ENTER: buka hasil pertama
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const firstLink = searchList.querySelector('a');
        if (firstLink) {
          e.preventDefault();
          firstLink.click();
        }
      }
      if (e.key === 'Escape') {
        searchDropdown.classList.remove('active');
        searchInput.blur();
      }
    });

    // KLIK DI LUAR: tutup dropdown
    document.addEventListener('click', (e) => {
      if (!searchBar.contains(e.target)) {
        searchDropdown.classList.remove('active');
      }
    });
  }
</script>

<style is:global>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(255,255,255,0.85);
    border-bottom: 1px solid var(--border, #e2e8f0);
    z-index: 100;
    transition: background 0.3s ease;
    width: 100%;
    max-width: 100vw;
  }
  html[data-mode="dark"] .topbar {
    background: rgba(10,10,10,0.85);
    border-bottom-color: var(--border, #1e1e1e);
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 16px;
    width: 100%;
    min-width: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text, #0f172a);
    font-weight: 700;
    font-size: 1.125rem;
    flex-shrink: 0;
    min-width: 0;
  }
  .logo-img {
    border-radius: 6px;
    flex-shrink: 0;
  }
  .logo-text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ========== SEARCH BAR BARU ========== */
  .search-bar {
    position: relative;
    flex: 1;
    max-width: 480px;
    min-width: 180px;
    z-index: 200;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--card-bg, #ffffff);
    border: 1.5px solid var(--border, #e2e8f0);
    border-radius: 10px;
    padding: 3px;
    transition: all 0.2s ease;
    height: 40px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .search-box:focus-within {
    border-color: var(--accent, #6366f1);
    box-shadow: 0 0 0 4px rgba(99,102,241,0.1), 0 1px 2px rgba(0,0,0,0.04);
  }

  .search-icon {
    color: var(--text-muted, #9ca3af);
    margin-left: 10px;
    margin-right: 8px;
    flex-shrink: 0;
    pointer-events: none;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--text, #0f172a);
    font-size: 0.875rem;
    font-family: inherit;
    height: 100%;
    min-width: 0;
    padding: 0 4px;
  }
  .search-input::placeholder {
    color: var(--text-muted, #9ca3af);
  }

  .search-btn {
    background: #111827;
    color: #ffffff;
    border: none;
    padding: 0 18px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s ease;
    height: 100%;
    margin: 1px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .search-btn:hover {
    background: #374151;
  }

  /* ========== DROPDOWN ========== */
  .search-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    width: 100%;
    background: var(--bg, #ffffff);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 12px;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    max-height: 400px;
    overflow-y: auto;
    overflow-x: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 9999;
    padding: 6px 0;
  }
  .search-dropdown.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .search-dropdown::-webkit-scrollbar {
    width: 6px;
  }
  .search-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-dropdown::-webkit-scrollbar-thumb {
    background: var(--border, #e2e8f0);
    border-radius: 3px;
  }

  .search-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .search-item {
    border-bottom: 1px solid var(--border, #f1f5f9);
  }
  .search-item:last-child {
    border-bottom: none;
  }

  .search-result-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 12px 16px;
    text-decoration: none !important;
    transition: background-color 0.12s ease;
    cursor: pointer;
    color: inherit;
    gap: 12px;
  }
  .search-result-item:hover {
    background-color: var(--bg-secondary, #f8fafc);
  }
  .search-result-item:hover .search-title {
    color: var(--accent, #6366f1);
  }

  .search-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    min-width: 0;
  }

  .search-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text, #0f172a);
    line-height: 1.4;
    text-decoration: none !important;
    border-bottom: none !important;
  }

  .search-desc {
    font-size: 0.75rem;
    color: var(--text-muted, #6b7280);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-time {
    font-size: 0.75rem;
    color: var(--text-muted, #9ca3af);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .search-empty {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    text-align: center;
    color: var(--text-muted, #94a3b8);
    font-size: 0.8125rem;
    gap: 8px;
  }

  /* ========== POST COUNT ========== */
  .post-count {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: inherit;
    flex-shrink: 0;
  }
  .post-count-badge {
    background: var(--accent, #6366f1);
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1;
    box-shadow: 0 0 0 2px var(--bg, #ffffff);
    transition: transform 0.2s ease;
  }
  .post-count-badge:hover {
    transform: scale(1.05);
  }
  html[data-mode="dark"] .post-count-badge {
    box-shadow: 0 0 0 2px var(--bg, #0a0a0a);
  }
  .post-count-pill {
    background: #dc2626;
    color: #fff;
    font-weight: 600;
    font-size: 0.8rem;
    padding: 5px 14px;
    border-radius: 6px;
    line-height: 1;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }

  /* ========== MENU TOGGLE ========== */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    color: var(--text, #0f172a);
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }
  .menu-toggle:hover {
    background: var(--bg-secondary, #f8fafc);
  }

  /* ========== TABLET ========== */
  @media (max-width: 768px) {
    .topbar-inner {
      padding: 0 12px;
      gap: 10px;
    }
    .search-bar {
      max-width: none;
      min-width: 0;
    }
    .search-box {
      height: 36px;
    }
    .search-btn {
      padding: 0 14px;
      font-size: 12px;
    }
    .search-dropdown {
      position: fixed;
      top: 66px;
      left: 12px;
      right: 12px;
      width: auto;
      min-width: auto;
    }
    .menu-toggle {
      display: flex;
    }
    .post-count-pill {
      display: none;
    }
    .post-count-badge {
      padding: 2px 6px;
      font-size: 0.7rem;
    }
  }

  /* ========== MOBILE KECIL ========== */
  @media (max-width: 480px) {
    .topbar {
      height: 56px;
    }
    .topbar-inner {
      padding: 0 10px;
      gap: 8px;
    }
    .logo-text {
      font-size: 1rem;
    }
    .search-box {
      height: 34px;
      padding: 2px;
    }
    .search-icon {
      width: 14px;
      height: 14px;
      margin-left: 8px;
      margin-right: 6px;
    }
    .search-input {
      font-size: 0.8rem;
    }
    .search-input::placeholder {
      font-size: 0.8rem;
    }
    .search-btn {
      padding: 0 10px;
      font-size: 11px;
    }
    .post-count {
      display: none;
    }
    .menu-toggle {
      width: 36px;
      height: 36px;
    }
    .menu-toggle svg {
      width: 20px;
      height: 20px;
    }
  }

  @media (max-width: 360px) {
    .logo-text {
      display: none;
    }
    .topbar-inner {
      gap: 6px;
    }
  }
</style>
