---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = await getCollection("blog", ({ data }) => !data.draft);
const postsData = posts.map(p => ({
  title: p.data.title,
  slug: p.id,
  description: p.data.description || "",
  category: p.data.category || "Uncategorized",
  thumbnail: p.data.thumbnail || p.data.heroImage || ""
}));
---

<header class="topbar">
  <div class="topbar-inner">
    <a href={`${base}/`} class="logo">
      <img src={`${base}/favicons/favicon-32x32.png`} alt="sinibaca" class="logo-img" width="28" height="28" />
      <span class="logo-text">sinibaca</span>
    </a>

    <div class="search-bar" data-posts={JSON.stringify(postsData)}>
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" placeholder="Cari artikel..." class="search-input" id="search-input" autocomplete="off" />
      <div class="search-dropdown" id="search-dropdown"></div>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const sidebar = document.querySelector(".sidebar-left");
  toggle?.addEventListener("click", () => {
    sidebar?.classList.toggle("mobile-open");
  });

  // Real-time search
  const searchBar = document.querySelector('.search-bar');
  const searchInput = document.getElementById('search-input');
  const searchDropdown = document.getElementById('search-dropdown');
  
  if (searchBar && searchInput && searchDropdown) {
    const posts = JSON.parse((searchBar as HTMLElement).dataset.posts || '[]');
    const base = window.location.pathname.startsWith('/sinibaca-v2') ? '/sinibaca-v2' : '';
    
    function highlightText(text: string, query: string) {
      if (!query) return text;
      const regex = new RegExp(`(${query})`, 'gi');
      return text.replace(regex, '<mark>$1</mark>');
    }
    
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      
      if (!query) {
        searchDropdown.innerHTML = '';
        searchDropdown.classList.remove('active');
        return;
      }
      
      const results = posts.filter((post: any) => 
        post.title.toLowerCase().includes(query) || 
        (post.description && post.description.toLowerCase().includes(query)) ||
        (post.category && post.category.toLowerCase().includes(query))
      ).slice(0, 3);
      
      if (results.length === 0) {
        searchDropdown.innerHTML = '<div class="search-empty">Tidak ada artikel</div>';
      } else {
        searchDropdown.innerHTML = results.map((post: any) => {
          const thumbUrl = post.thumbnail ? (post.thumbnail.startsWith('/') ? `${base}${post.thumbnail}` : `${base}/${post.thumbnail}`) : `${base}/images/placeholder.jpg`;
          const highlightedTitle = highlightText(post.title, query);
          return `
            <a href="${base}/blog/${post.slug}" class="search-result">
              <div class="search-thumb">
                <img src="${thumbUrl}" alt="" loading="lazy" onerror="this.style.display='none'" />
              </div>
              <div class="search-info">
                <div class="search-title">${highlightedTitle}</div>
                <div class="search-meta">
                  <span class="search-cat">${post.category}</span>
                </div>
              </div>
            </a>
          `;
        }).join('');
      }
      
      searchDropdown.classList.add('active');
    });
    
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement)?.closest('.search-bar')) {
        searchDropdown.classList.remove('active');
      }
    });
  }
</script>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid var(--border);
    height: 60px;
    transition: background 0.3s ease;
  }
  html[data-mode="dark"] .topbar {
    background: rgba(10, 10, 10, 0.8);
  }
  .topbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    flex-shrink: 0;
  }
  .logo-img {
    border-radius: 6px;
    display: block;
  }
  .logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .search-bar {
    flex: 1;
    max-width: 400px;
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    color: var(--text-light);
    pointer-events: none;
    z-index: 2;
  }
  .search-input {
    width: 100%;
    padding: 8px 12px 8px 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text);
    font-size: 0.875rem;
    outline: none;
    transition: all 0.2s;
  }
  .search-input:focus {
    border-color: var(--accent);
    background: var(--bg);
  }
  .search-input::placeholder {
    color: var(--text-light);
  }

  /* Dropdown - Polished */
  .search-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    width: 320px; /* <-- TETAP 320px, tidak full width */
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    display: none;
    overflow: hidden;
    z-index: 100;
    animation: dropdownFade 0.2s ease;
  }
  @keyframes dropdownFade {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .search-dropdown.active {
    display: block;
  }

  /* Search Result Card */
  .search-result {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s ease;
    cursor: pointer;
  }
  .search-result:last-child {
    border-bottom: none;
  }
  .search-result:hover {
    background: var(--bg-secondary);
  }

  /* Thumbnail - FIXED SIZE */
  .search-thumb {
    width: 48px;
    height: 48px;
    min-width: 48px;
    min-height: 48px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-secondary);
    flex-shrink: 0;
  }
  .search-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Info */
  .search-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }
  .search-title {
    font-weight: 600;
    font-size: 0.8rem;
    line-height: 1.3;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .search-title mark {
    background: rgba(99, 102, 241, 0.2);
    color: var(--accent);
    font-weight: 700;
    border-radius: 2px;
    padding: 0 2px;
  }
  .search-meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .search-cat {
    font-size: 0.65rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: rgba(99, 102, 241, 0.1);
    padding: 2px 6px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .search-empty {
    padding: 16px 12px;
    color: var(--text-muted);
    font-size: 0.875rem;
    text-align: center;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
  }
  .menu-toggle:hover {
    background: var(--bg-secondary);
  }
  @media (max-width: 900px) {
    .menu-toggle { display: block; }
    .search-bar { display: none; }
  }
  @media (max-width: 1200px) {
    .search-bar { max-width: 300px; }
  }
</style>